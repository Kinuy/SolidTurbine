## project data
project_name testproject
project_id 00000
project_revision R00
project_date 250811
project_engineer TW

switch_calc_rotormap 1   # or 1 to enable
switch_calc_blade_and_rotor_noise 0   # or 1 to enable

## airfoil ,blade, controller data
# airfoil_geometry_files_file AirfoilGeometry.dat
airfoil_geometry_files_file TestCase/Input_Turbine/TURBINE_PORT/AirfoilGeometry_E.dat
# airfoil_performance_files_file AirfoilPerformance.dat
airfoil_performance_files_file TestCase/Input_Turbine/TURBINE_PORT/AirfoilPerformance_E.dat
blade_geometry_file TestCase/Input_Turbine/TURBINE_PORT/BladeGeometry_E.dat
# blade_geometry_file BladeGeometry.dat
turbine_controller_file TurbineControlSettings.dat


## turbine configuration
turbine_is_horizontal true
number_of_blades 3 #[-]
# hub_radius 1.544 #[m]
cone 0.0 #[deg]
yaw 0.0 #[deg]
tilt 0.0 #[deg]
tower_dist 0.0 #[m]
hub_height 100 #[m]

## turbine operation settings
rated_rotorspeed 7.2 #[rpm]
min_rotorspeed 4.82 #[rpm]
rated_electrical_power 8000000 #[W]

## simulation settings
# range vectors: start end step
simulation_is_time_based false
rotor_azimuth_psi_increment  0 # [deg] → scalar at psi=0 (fast)
#rotor_azimuth_psi_increment  45     # [deg] → 24 positions [0, 15, 30, ..., 345] 
wind_speed_range 3 15 1 #[m/s]
tip_speed_ratio_range 5 15 1 #[-]
pitch_angle_range 0 2 0.5 #[deg]
aep_vmean_range 4 11 1 #[m/s]
aep_money_kwh 0.4 #[EUR/kWh]

rotormap_v_tip 80.0 #[-]
rotormap_lambda_range 4 15 1 #[-]
rotormap_pitch_range -1 5 0.5 #[deg]

tip_extra_dist 0.0 #[m]
convergence_tol 0.001 #[-]
power_mode L0 #[L0|POWER]
max_dp_dn 0.1 #[W/rpm]
n_nenn 10 #[rpm]
lambda_opt 12.0 #[-]
kinematic_viscosity 1.48e-5 #[m^2/s]
speed_of_sound 340 #[m/s]
air_density 1.225 #[kg/m^3]
temperature 293.15 #[K]
aep_k_factor 2 #[-]
wake_transition 0.3539 #[-]

## noise calc settings
noise_bl_tripping 2 # ITRIP	2         #Boudary layer trip: no trip = 0 BPM, heavy trip = 1 (BPM only), light trip = 2
noise_bl_properties_calc_method 2 # X_BLMethod	2    #X_BLMethod    Integer describing calculation method for boundary layer properties:  1 = BPM ; 2 = Xfoil  
noise_tbl_noise_calc_method 1 # TBL_Method	1    #Integer describing TBL noise calculation: 0 = none ; 1 = BPM ; 2 = TNO  
noise_ti_noise_calc_method 2 # TI_Method	2     #Integer describing TI noise calculation: 0 = none ; 1 = Amiet (flat plate) ; 2 = Guidati ; 3 = Simplified                                                                                
noise_calc_blunt_te_noise 1 # IBLUNT	1        #FLAG TO COMPUTE BLUNTNESS NOISE:      0 = No ; 1 = Yes                 
noise_calc_lam_bl_noise 1 # ILAM	1          #FLAG TO COMPUTE LBL NOISE:          0 = No ; 1 = Yes   

noise_ground_distance 10.0 #"Horizontal distance from tower base to observer [m] (IEC)"
noise_overhang 2.0 #"Rotor overhang from tower centreline [m]"

